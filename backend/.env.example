# Base de datos (PostgreSQL - usar Neon en producción)
# Crear cuenta gratis en neon.tech, copiar connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT
JWT_SECRET="cambia-esto-en-produccion-minimo-32-caracteres"
JWT_REFRESH_SECRET="cambia-esto-en-produccion-minimo-32-caracteres-2"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL="http://localhost:5173"

# Email (dejar vacío en dev para usar Ethereal automático)
# En producción usar Gmail con App Password o SendGrid
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Sistema Cotizaciones <noreply@tudominio.com>"
